# Required: AIS data feed
AISSTREAM_API_KEY=your_aisstream_api_key_here

# Optional: Push live snapshots to GitHub for public hosting
# Create a Personal Access Token with "repo" scope at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=username/hormuz
GITHUB_DATA_BRANCH=data

# Optional: OpenSky Network aircraft tracking (OAuth2 client credentials)
# Register at https://opensky-network.org/ — 4000 API credits/day limit
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# Optional: Set for GitHub Pages frontend build
# VITE_GITHUB_RAW_BASE=https://raw.githubusercontent.com/username/hormuz/data
# VITE_API_BASE=http://your-nas-ip:3001
